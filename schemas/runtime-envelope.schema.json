{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoauth.local/schemas/runtime-envelope.schema.json",
  "title": "Runtime Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope_id", "request_id", "subject_id", "requester_id", "authority_verdict_id", "action", "resource", "payload_hash", "policy_version", "invariant_version", "channel_id", "nonce", "expires_at", "audit_sink_id"],
  "properties": {
    "envelope_id": { "type": "string" },
    "request_id": { "type": "string" },
    "subject_id": { "type": "string" },
    "requester_id": { "type": "string" },
    "authority_verdict_id": { "type": "string" },
    "delegation_id": { "type": "string" },
    "action": { "type": "string" },
    "resource": { "type": "string" },
    "payload_hash": { "type": "string" },
    "policy_version": { "type": "string" },
    "invariant_version": { "type": "string" },
    "channel_id": { "type": "string" },
    "nonce": { "type": "string" },
    "expires_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
    "audit_sink_id": { "type": "string" }
  }
