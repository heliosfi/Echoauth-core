{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoauth.local/schemas/event-bus-v2-authority-intake-governance-admission.schema.json",
  "title": "EchoAuth Event Bus v2 Authority Intake Governance Admission",
  "description": "Structure-only governance admission evidence. Admission does not assign authority, approve a contract, resolve a blocker, authorize execution, or mutate the current register.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "admission_schema_version",
    "admission_id",
    "intake_id",
    "blocker_id",
    "source_intake_status",
    "verification_record_reference",
    "verification_record_hash",
    "verification_verifier_party_reference_hash",
    "governance_reviewer_party_reference",
    "governance_reviewer_party_reference_hash",
    "governance_reviewer_authority_evidence_reference",
    "governance_reviewer_authority_evidence_hash",
    "evidence_provenance",
    "scope_alignment",
    "reviewer_independence_check",
    "admission_outcome",
    "admission_reason_codes",
    "resulting_intake_status",
    "admitted_at",
    "hold_status",
    "contains_credentials",
    "contains_secrets",
    "contains_excess_personal_data",
    "self_review_detected",
    "verifier_authority_evidence_reused",
    "inferred_governance_authority",
    "identity_established",
    "party_assigned",
    "authority_assigned",
    "authority_reference_granted",
    "approval_granted",
    "contract_approved",
    "blocker_resolved",
    "blockers_resolved",
    "execution_authorized",
    "runtime_enabled",
    "current_register_mutated",
    "runtime_effect"
  ],
  "properties": {
    "admission_schema_version": { "const": "2.0.0" },
    "admission_id": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "intake_id": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "blocker_id": {
      "type": "string",
      "enum": [
        "EVT2-B01",
        "EVT2-B02",
        "EVT2-B03",
        "EVT2-B04",
        "EVT2-B05",
        "EVT2-B06",
        "EVT2-B07",
        "EVT2-B08"
      ]
    },
    "source_intake_status": { "const": "VERIFIED_PENDING_GOVERNANCE" },
    "verification_record_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "verification_record_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "verification_verifier_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "governance_reviewer_party_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "governance_reviewer_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "governance_reviewer_authority_evidence_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "governance_reviewer_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "evidence_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_category", "source_reference", "evidence_hash", "observed_at"],
      "properties": {
        "source_category": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "source_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "observed_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" }
      }
    },
    "scope_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "verified_scope_hash", "reviewer_scope_hash", "outcome"],
      "properties": {
        "blocker_id": {
          "type": "string",
          "enum": [
            "EVT2-B01",
            "EVT2-B02",
            "EVT2-B03",
            "EVT2-B04",
            "EVT2-B05",
            "EVT2-B06",
            "EVT2-B07",
            "EVT2-B08"
          ]
        },
        "verified_scope_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "reviewer_scope_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "outcome": { "const": "ALIGNED" }
      }
    },
    "reviewer_independence_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_verifier_party_reference_hash",
        "governance_reviewer_party_reference_hash",
        "verification_authority_evidence_hash",
        "governance_reviewer_authority_evidence_hash",
        "outcome",
        "evidence_hash"
      ],
      "properties": {
        "verification_verifier_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "governance_reviewer_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "verification_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "governance_reviewer_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "outcome": { "const": "DISTINCT_AND_INDEPENDENT" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" }
      }
    },
    "admission_outcome": { "enum": ["ACCEPTED_FOR_REVIEW", "REJECTED"] },
    "admission_reason_codes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "VERIFICATION_RECORD_INVALID",
          "VERIFICATION_HASH_MISMATCH",
          "GOVERNANCE_AUTHORITY_EVIDENCE_INVALID",
          "MISSING_PROVENANCE",
          "SCOPE_MISMATCH",
          "SELF_REVIEW",
          "REUSED_VERIFIER_AUTHORITY_EVIDENCE",
          "CONFLICTING_EVIDENCE"
        ]
      }
    },
    "resulting_intake_status": { "enum": ["ACCEPTED_FOR_REVIEW", "REJECTED"] },
    "admitted_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" },
    "hold_status": { "const": "ACTIVE" },
    "contains_credentials": { "const": false },
    "contains_secrets": { "const": false },
    "contains_excess_personal_data": { "const": false },
    "self_review_detected": { "const": false },
    "verifier_authority_evidence_reused": { "const": false },
    "inferred_governance_authority": { "const": false },
    "identity_established": { "const": false },
    "party_assigned": { "const": false },
    "authority_assigned": { "const": false },
    "authority_reference_granted": { "const": false },
    "approval_granted": { "const": false },
    "contract_approved": { "const": false },
    "blocker_resolved": { "const": false },
    "blockers_resolved": { "const": false },
    "execution_authorized": { "const": false },
    "runtime_enabled": { "const": false },
    "current_register_mutated": { "const": false },
    "runtime_effect": { "const": "NONE" }
  },
  "allOf": [
    {
      "if": { "properties": { "admission_outcome": { "const": "ACCEPTED_FOR_REVIEW" } }, "required": ["admission_outcome"] },
      "then": {
        "properties": {
          "resulting_intake_status": { "const": "ACCEPTED_FOR_REVIEW" },
          "admission_reason_codes": { "maxItems": 0 }
        }
      },
      "else": {
        "properties": {
          "resulting_intake_status": { "const": "REJECTED" },
          "admission_reason_codes": { "minItems": 1 }
        }
      }
    }
  ]
}
