{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoauth.local/schemas/sniperbot-fsm-transition-decision.schema.json",
  "title": "SniperBot FSM Transition Decision Schema",
  "description": "Schema-only representation of a pure, deterministic, side-effect-free, non-executing transition decision. This schema creates no authority, state mutation, persistence, network call, command, order, broker, credential, runtime, or execution capability.",
  "type": "object",
  "additionalProperties": false,
  "required": ["request", "decision"],
  "properties": {
    "request": { "$ref": "#/$defs/TransitionRequest" },
    "decision": { "$ref": "#/$defs/TransitionDecision" }
  },
  "$defs": {
    "State": {
      "type": "string",
      "enum": ["PAUSE", "READY", "ARMED_MANUAL", "ARMED_AUTO", "IN_TRADE", "LOCKOUT"]
    },
    "TransitionRequestName": {
      "type": "string",
      "enum": [
        "PAUSE_TO_READY",
        "READY_TO_ARMED_MANUAL",
        "READY_TO_ARMED_AUTO",
        "ARMED_AUTO_TO_IN_TRADE",
        "ARMED_MANUAL_TO_IN_TRADE",
        "IN_TRADE_TO_READY",
        "IN_TRADE_TO_PAUSE",
        "ANY_TO_LOCKOUT",
        "LOCKOUT_TO_PAUSE"
      ]
    },
    "CanonicalTransitionSubject": {
      "oneOf": [
        {
          "required": ["current_state", "requested_state", "transition_request"],
          "properties": {
            "current_state": { "const": "PAUSE" },
            "requested_state": { "const": "READY" },
            "transition_request": { "const": "PAUSE_TO_READY" }
          }
        },
        {
          "required": ["current_state", "requested_state", "transition_request"],
          "properties": {
            "current_state": { "const": "READY" },
            "requested_state": { "const": "ARMED_MANUAL" },
            "transition_request": { "const": "READY_TO_ARMED_MANUAL" }
          }
        },
        {
          "required": ["current_state", "requested_state", "transition_request"],
          "properties": {
            "current_state": { "const": "READY" },
            "requested_state": { "const": "ARMED_AUTO" },
            "transition_request": { "const": "READY_TO_ARMED_AUTO" }
          }
        },
        {
          "required": ["current_state", "requested_state", "transition_request"],
          "properties": {
            "current_state": { "const": "ARMED_AUTO" },
            "requested_state": { "const": "IN_TRADE" },
            "transition_request": { "const": "ARMED_AUTO_TO_IN_TRADE" }
          }
        },
        {
          "required": ["current_state", "requested_state", "transition_request"],
          "properties": {
            "current_state": { "const": "ARMED_MANUAL" },
            "requested_state": { "const": "IN_TRADE" },
            "transition_request": { "const": "ARMED_MANUAL_TO_IN_TRADE" }
          }
        },
        {
          "required": ["current_state", "requested_state", "transition_request"],
          "properties": {
            "current_state": { "const": "IN_TRADE" },
            "requested_state": { "const": "READY" },
            "transition_request": { "const": "IN_TRADE_TO_READY" }
          }
        },
        {
          "required": ["current_state", "requested_state", "transition_request"],
          "properties": {
            "current_state": { "const": "IN_TRADE" },
            "requested_state": { "const": "PAUSE" },
            "transition_request": { "const": "IN_TRADE_TO_PAUSE" }
          }
        },
        {
          "required": ["requested_state", "transition_request"],
          "properties": {
            "requested_state": { "const": "LOCKOUT" },
            "transition_request": { "const": "ANY_TO_LOCKOUT" }
          }
        },
        {
          "required": ["current_state", "requested_state", "transition_request"],
          "properties": {
            "current_state": { "const": "LOCKOUT" },
            "requested_state": { "const": "PAUSE" },
            "transition_request": { "const": "LOCKOUT_TO_PAUSE" }
          }
        }
      ]
    },
    "ExternalFacts": {
      "type": "object",
      "description": "Immutable facts already determined by an external authority. The FSM does not calculate, discover, verify through calls, refresh, mutate, or persist them.",
      "additionalProperties": false,
      "required": [
        "readiness_preconditions_satisfied",
        "confirmed_position_exists",
        "position_closed",
        "cooldown_complete",
        "lockout_required",
        "logging_failure_indicated",
        "reset_facts_explicit"
      ],
      "properties": {
        "readiness_preconditions_satisfied": { "type": "boolean" },
        "confirmed_position_exists": { "type": "boolean" },
        "position_closed": { "type": "boolean" },
        "cooldown_complete": { "type": "boolean" },
        "lockout_required": { "type": "boolean" },
        "logging_failure_indicated": { "type": "boolean" },
        "reset_facts_explicit": { "type": "boolean" }
      }
    },
    "AuthorityEvidence": {
      "type": "object",
      "description": "Caller-supplied representation of an already-bounded EchoAuth result. EchoAuth alone owns permission authority; this schema does not grant, validate, repair, reinterpret, or bypass it.",
      "additionalProperties": false,
      "required": ["presence", "subject_scope", "currentness", "revocation", "validity_outcome", "authority_reference"],
      "properties": {
        "presence": { "type": "string", "enum": ["PRESENT", "ABSENT"] },
        "subject_scope": { "type": "string", "minLength": 1 },
        "currentness": { "type": "string", "enum": ["CURRENT", "STALE"] },
        "revocation": { "type": "string", "enum": ["NON_REVOKED", "REVOKED"] },
        "validity_outcome": { "type": "string", "enum": ["VALID", "INVALID", "AMBIGUOUS", "OUT_OF_SCOPE"] },
        "authority_reference": { "type": "string", "minLength": 1 }
      }
    },
    "ValidAuthorityEvidence": {
      "allOf": [
        { "$ref": "#/$defs/AuthorityEvidence" },
        {
          "properties": {
            "presence": { "const": "PRESENT" },
            "currentness": { "const": "CURRENT" },
            "revocation": { "const": "NON_REVOKED" },
            "validity_outcome": { "const": "VALID" }
          }
        }
      ]
    },
    "OrdinaryEvaluationFacts": {
      "allOf": [
        { "$ref": "#/$defs/ExternalFacts" },
        {
          "properties": { "lockout_required": { "const": false } },
          "not": {
            "required": ["confirmed_position_exists", "position_closed"],
            "properties": {
              "confirmed_position_exists": { "const": true },
              "position_closed": { "const": true }
            }
          }
        }
      ]
    },
    "AuthorityAbsentWinner": {
      "allOf": [
        { "$ref": "#/$defs/AuthorityEvidence" },
        { "properties": { "presence": { "const": "ABSENT" } } }
      ]
    },
    "AuthorityStaleWinner": {
      "allOf": [
        { "$ref": "#/$defs/AuthorityEvidence" },
        {
          "properties": {
            "presence": { "const": "PRESENT" },
            "currentness": { "const": "STALE" }
          }
        }
      ]
    },
    "AuthorityRevokedWinner": {
      "allOf": [
        { "$ref": "#/$defs/AuthorityEvidence" },
        {
          "properties": {
            "presence": { "const": "PRESENT" },
            "currentness": { "const": "CURRENT" },
            "revocation": { "const": "REVOKED" }
          }
        }
      ]
    },
    "AuthorityOutOfScopeWinner": {
      "allOf": [
        { "$ref": "#/$defs/AuthorityEvidence" },
        {
          "properties": {
            "presence": { "const": "PRESENT" },
            "currentness": { "const": "CURRENT" },
            "revocation": { "const": "NON_REVOKED" },
            "validity_outcome": { "const": "OUT_OF_SCOPE" }
          }
        }
      ]
    },
    "AuthorityInvalidWinner": {
      "allOf": [
        { "$ref": "#/$defs/AuthorityEvidence" },
        {
          "properties": {
            "presence": { "const": "PRESENT" },
            "currentness": { "const": "CURRENT" },
            "revocation": { "const": "NON_REVOKED" },
            "validity_outcome": { "enum": ["INVALID", "AMBIGUOUS"] }
          }
        }
      ]
    },
    "AuthorityValidWinner": {
      "allOf": [
        { "$ref": "#/$defs/AuthorityEvidence" },
        {
          "properties": {
            "presence": { "const": "PRESENT" },
            "currentness": { "const": "CURRENT" },
            "revocation": { "const": "NON_REVOKED" },
            "validity_outcome": { "const": "VALID" }
          }
        }
      ]
    },
    "TransitionRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_state", "requested_state", "transition_request", "correlation_reference", "external_facts", "authority_evidence"],
      "properties": {
        "current_state": { "$ref": "#/$defs/State" },
        "requested_state": { "$ref": "#/$defs/State" },
        "transition_request": { "$ref": "#/$defs/TransitionRequestName" },
        "correlation_reference": { "type": "string", "minLength": 1, "description": "Mandatory opaque caller reference; it is not generated, interpreted, persisted, or audited by the FSM." },
        "external_facts": { "$ref": "#/$defs/ExternalFacts" },
        "authority_evidence": {
          "description": "Required as bounded input for arming and reset decisions; null means authority evidence is not applicable in the current context, does not represent absent or failed authority evidence, and never grants permission.",
          "oneOf": [{ "$ref": "#/$defs/AuthorityEvidence" }, { "type": "null" }]
        }
      }
    },
    "ReasonCode": {
      "type": "string",
      "enum": [
        "ALLOWED",
        "UNDEFINED_TRANSITION",
        "UNKNOWN_STATE",
        "READINESS_FACTS_MISSING",
        "AUTHORITY_MISSING",
        "AUTHORITY_INVALID",
        "AUTHORITY_STALE",
        "AUTHORITY_REVOKED",
        "AUTHORITY_OUT_OF_SCOPE",
        "TRANSITION_FOUNDER_DENIED",
        "CONFIRMED_POSITION_FACT_MISSING",
        "POSITION_CLOSED_FACT_MISSING",
        "COOLDOWN_FACT_MISSING",
        "LOCKOUT_REQUIRED",
        "RESET_EVIDENCE_MISSING",
        "RESET_FACTS_MISSING",
        "AMBIGUOUS_OR_CONTRADICTORY_INPUT"
      ]
    },
    "RequiredAction": {
      "type": "string",
      "enum": ["NONE", "HUMAN_REVIEW", "GOVERNANCE_REVIEW", "FOUNDER_AUTHORITY_REQUIRED", "RESET_REQUIRED"]
    },
    "TransitionDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_state", "requested_state", "allowed", "resulting_state", "reason_code", "required_next_human_or_governance_action", "correlation_reference"],
      "properties": {
        "current_state": { "$ref": "#/$defs/State" },
        "requested_state": { "$ref": "#/$defs/State" },
        "allowed": { "type": "boolean" },
        "resulting_state": { "$ref": "#/$defs/State", "description": "Descriptive only; no state mutation occurs." },
        "reason_code": { "$ref": "#/$defs/ReasonCode" },
        "required_next_human_or_governance_action": { "$ref": "#/$defs/RequiredAction" },
        "correlation_reference": { "type": "string", "minLength": 1, "description": "Must equal the request reference; the FSM does not generate, interpret, persist, or audit it. Exact equality is enforced by the future pure evaluator because Draft 2020-12 cannot compare sibling values." }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "request": {
            "properties": {
              "external_facts": { "properties": { "lockout_required": { "const": true } } }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "allowed": { "const": false },
              "resulting_state": { "const": "LOCKOUT" },
              "reason_code": { "const": "LOCKOUT_REQUIRED" },
              "required_next_human_or_governance_action": { "const": "RESET_REQUIRED" }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "requested_state", "transition_request", "external_facts"],
            "properties": {
              "current_state": { "const": "LOCKOUT" },
              "external_facts": {
                "not": {
                  "required": ["confirmed_position_exists", "position_closed"],
                  "properties": {
                    "confirmed_position_exists": { "const": true },
                    "position_closed": { "const": true }
                  }
                }
              }
            },
            "not": {
              "required": ["requested_state", "transition_request"],
              "properties": {
                "requested_state": { "const": "PAUSE" },
                "transition_request": { "const": "LOCKOUT_TO_PAUSE" }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "current_state": { "const": "LOCKOUT" },
              "allowed": { "const": false },
              "resulting_state": { "const": "LOCKOUT" },
              "reason_code": { "const": "LOCKOUT_REQUIRED" },
              "required_next_human_or_governance_action": { "const": "RESET_REQUIRED" }
            }
          }
        }
      }
    },
    {
      "description": "Closed transition request identifiers with non-canonical state pairs are governed undefined transitions after higher-priority branches.",
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "requested_state", "transition_request", "external_facts"],
            "properties": {
              "current_state": { "not": { "const": "LOCKOUT" } },
              "external_facts": {
                "properties": { "lockout_required": { "const": false } },
                "not": {
                  "required": ["confirmed_position_exists", "position_closed"],
                  "properties": {
                    "confirmed_position_exists": { "const": true },
                    "position_closed": { "const": true }
                  }
                }
              }
            },
            "not": { "$ref": "#/$defs/CanonicalTransitionSubject" }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "allowed": { "const": false },
              "reason_code": { "const": "UNDEFINED_TRANSITION" },
              "required_next_human_or_governance_action": { "const": "GOVERNANCE_REVIEW" }
            }
          }
        }
      }
    },
    {
      "description": "ANY_TO_LOCKOUT without an active lockout fact is a governed undefined transition outside the current lockout gate.",
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "transition_request", "external_facts"],
            "properties": {
              "current_state": { "not": { "const": "LOCKOUT" } },
              "transition_request": { "const": "ANY_TO_LOCKOUT" },
              "external_facts": {
                "properties": { "lockout_required": { "const": false } },
                "not": {
                  "required": ["confirmed_position_exists", "position_closed"],
                  "properties": {
                    "confirmed_position_exists": { "const": true },
                    "position_closed": { "const": true }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "allowed": { "const": false },
              "reason_code": { "const": "UNDEFINED_TRANSITION" },
              "required_next_human_or_governance_action": { "const": "GOVERNANCE_REVIEW" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request": {
            "properties": {
              "current_state": { "const": "READY" },
              "requested_state": { "const": "ARMED_AUTO" },
              "transition_request": { "const": "READY_TO_ARMED_AUTO" },
              "external_facts": {
                "properties": { "lockout_required": { "const": false } },
                "not": {
                  "required": ["confirmed_position_exists", "position_closed"],
                  "properties": {
                    "confirmed_position_exists": { "const": true },
                    "position_closed": { "const": true }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "allowed": { "const": false },
              "resulting_state": { "const": "READY" },
              "reason_code": { "const": "TRANSITION_FOUNDER_DENIED" },
              "required_next_human_or_governance_action": { "const": "FOUNDER_AUTHORITY_REQUIRED" }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "requested_state"],
            "properties": {
              "current_state": { "const": "READY" },
              "requested_state": { "const": "ARMED_MANUAL" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "request": {
            "properties": { "authority_evidence": { "$ref": "#/$defs/AuthorityEvidence" } }
          }
        }
      }
    },
    {
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "requested_state"],
            "properties": {
              "current_state": { "const": "LOCKOUT" },
              "requested_state": { "const": "PAUSE" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "request": {
            "properties": { "authority_evidence": { "$ref": "#/$defs/AuthorityEvidence" } }
          }
        }
      }
    },
    {
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "requested_state", "transition_request"],
            "properties": {
              "current_state": { "const": "ARMED_MANUAL" },
              "requested_state": { "const": "IN_TRADE" },
              "transition_request": { "const": "ARMED_MANUAL_TO_IN_TRADE" },
              "external_facts": {
                "properties": { "lockout_required": { "const": false } },
                "not": {
                  "required": ["confirmed_position_exists", "position_closed"],
                  "properties": {
                    "confirmed_position_exists": { "const": true },
                    "position_closed": { "const": true }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "allowed": { "const": false },
              "resulting_state": { "const": "ARMED_MANUAL" },
              "reason_code": { "const": "UNDEFINED_TRANSITION" },
              "required_next_human_or_governance_action": { "const": "GOVERNANCE_REVIEW" }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "requested_state", "transition_request"],
            "properties": {
              "current_state": { "const": "IN_TRADE" },
              "requested_state": { "const": "READY" },
              "transition_request": { "const": "IN_TRADE_TO_READY" },
              "external_facts": {
                "properties": { "lockout_required": { "const": false } },
                "not": {
                  "required": ["confirmed_position_exists", "position_closed"],
                  "properties": {
                    "confirmed_position_exists": { "const": true },
                    "position_closed": { "const": true }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "allowed": { "const": false },
              "resulting_state": { "const": "IN_TRADE" },
              "reason_code": { "const": "UNDEFINED_TRANSITION" },
              "required_next_human_or_governance_action": { "const": "GOVERNANCE_REVIEW" }
            }
          }
        }
      }
    },
    {
      "description": "Contradictory position facts produce the governed human-review denial after forced-lockout handling.",
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["external_facts"],
            "properties": {
              "external_facts": {
                "required": ["confirmed_position_exists", "position_closed", "lockout_required"],
                "properties": {
                  "confirmed_position_exists": { "const": true },
                  "position_closed": { "const": true },
                  "lockout_required": { "const": false }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "allowed": { "const": false },
              "reason_code": { "const": "AMBIGUOUS_OR_CONTRADICTORY_INPUT" },
              "required_next_human_or_governance_action": { "const": "HUMAN_REVIEW" }
            }
          }
        }
      }
    },
    {
      "description": "PAUSE_TO_READY decision parity after higher-priority branches.",
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "requested_state", "transition_request", "external_facts"],
            "properties": {
              "current_state": { "const": "PAUSE" },
              "requested_state": { "const": "READY" },
              "transition_request": { "const": "PAUSE_TO_READY" },
              "external_facts": { "$ref": "#/$defs/OrdinaryEvaluationFacts" }
            }
          }
        }
      },
      "then": {
        "oneOf": [
          {
            "properties": {
              "request": {
                "properties": {
                  "external_facts": {
                    "properties": { "readiness_preconditions_satisfied": { "const": false } }
                  }
                }
              },
              "decision": {
                "properties": {
                  "allowed": { "const": false },
                  "resulting_state": { "const": "PAUSE" },
                  "reason_code": { "const": "READINESS_FACTS_MISSING" },
                  "required_next_human_or_governance_action": { "const": "GOVERNANCE_REVIEW" }
                }
              }
            }
          },
          {
            "properties": {
              "request": {
                "properties": {
                  "external_facts": {
                    "properties": { "readiness_preconditions_satisfied": { "const": true } }
                  }
                }
              },
              "decision": {
                "properties": {
                  "allowed": { "const": true },
                  "resulting_state": { "const": "READY" },
                  "reason_code": { "const": "ALLOWED" },
                  "required_next_human_or_governance_action": { "const": "NONE" }
                }
              }
            }
          }
        ]
      }
    },
    {
      "description": "ARMED_AUTO_TO_IN_TRADE decision parity after higher-priority branches.",
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
            "required": ["current_state", "requested_state", "transition_request", "external_facts"],
            "properties": {
              "current_state": { "const": "ARMED_AUTO" },
              "requested_state": { "const": "IN_TRADE" },
              "transition_request": { "const": "ARMED_AUTO_TO_IN_TRADE" },
              "external_facts": { "$ref": "#/$defs/OrdinaryEvaluationFacts" }
            }
          }
        }
      },
      "then": {
        "oneOf": [
          {
            "properties": {
              "request": {
                "properties": {
                  "external_facts": {
                    "properties": { "confirmed_position_exists": { "const": false } }
                  }
                }
              },
              "decision": {
                "properties": {
                  "allowed": { "const": false },
                  "resulting_state": { "const": "ARMED_AUTO" },
                  "reason_code": { "const": "CONFIRMED_POSITION_FACT_MISSING" },
                  "required_next_human_or_governance_action": { "const": "GOVERNANCE_REVIEW" }
                }
              }
            }
          },
          {
            "properties": {
              "request": {
                "properties": {
                  "external_facts": {
                    "properties": { "confirmed_position_exists": { "const": true } }
                  }
                }
              },
              "decision": {
                "properties": {
                  "allowed": { "const": true },
                  "resulting_state": { "const": "IN_TRADE" },
                  "reason_code": { "const": "ALLOWED" },
                  "required_next_human_or_governance_action": { "const": "NONE" }
                }
              }
            }
          }
        ]
      }
    },
    {
      "description": "IN_TRADE_TO_PAUSE decision parity after higher-priority branches.",
      "if": {
        "required": ["request"],
        "properties": {
          "request": {
