{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoauth.local/schemas/recovery-review-protocol.schema.json",
  "title": "Recovery Review Protocol Evidence",
  "description": "Recovery-specific protocol evidence. This is not a general Review outcome and does not authorize the original action.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_id",
    "protocol_version",
    "protocol_status",
    "request_id",
    "halt_decision_id",
    "halt_decision_evidence_hash",
    "review_decision_id",
    "review_decision_evidence_hash",
    "reviewer_id",
    "reviewer_authority_reference",
    "reviewer_authority_resolution_id",
    "reviewer_authority_evidence_hash",
    "permitted_recovery_path",
    "scope",
    "expires_at",
    "evidence_hash"
  ],
  "properties": {
    "protocol_id": { "type": "string", "minLength": 1 },
    "protocol_version": { "type": "string", "minLength": 1 },
    "protocol_status": { "type": "string", "enum": ["active", "revoked", "expired"] },
    "request_id": { "type": "string", "minLength": 1 },
    "halt_decision_id": { "type": "string", "minLength": 1 },
    "halt_decision_evidence_hash": { "type": "string", "minLength": 1 },
    "review_decision_id": { "type": "string", "minLength": 1 },
    "review_decision_evidence_hash": { "type": "string", "minLength": 1 },
    "reviewer_id": { "type": "string", "minLength": 1 },
    "reviewer_authority_reference": { "type": "string", "minLength": 1 },
    "reviewer_authority_resolution_id": { "type": "string", "minLength": 1 },
    "reviewer_authority_evidence_hash": { "type": "string", "minLength": 1 },
    "permitted_recovery_path": { "const": "revalidate_request" },
    "scope": { "$ref": "common.schema.json#/$defs/CanonicalJsonObject" },
    "expires_at": { "type": "string", "format": "date-time" },
    "evidence_hash": { "type": "string", "minLength": 1 }
  }
}
