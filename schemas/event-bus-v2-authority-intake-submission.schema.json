{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoauth.local/schemas/event-bus-v2-authority-intake-submission.schema.json",
  "title": "EchoAuth Event Bus v2 Authority Intake Submission",
  "description": "Structure-only submission evidence. Conformance does not establish identity, authority, assignment, approval, blocker resolution, or runtime permission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "submission_schema_version",
    "intake_id",
    "blocker_id",
    "owner_role",
    "proposed_accountable_party_id",
    "proposed_authority_source",
    "proposed_authority_reference",
    "proposed_authority_scope",
    "submission_evidence_hash",
    "submitted_at",
    "intake_status",
    "submitted_evidence_status",
    "accountable_party_status",
    "authority_reference_status",
    "contains_credentials",
    "contains_secrets",
    "contains_unnecessary_personal_data",
    "identity_established",
    "authority_established",
    "party_assigned",
    "approval_granted",
    "blocker_resolved"
  ],
  "properties": {
    "submission_schema_version": { "const": "2.0.0" },
    "intake_id": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "blocker_id": {
      "type": "string",
      "enum": [
        "EVT2-B01",
        "EVT2-B02",
        "EVT2-B03",
        "EVT2-B04",
        "EVT2-B05",
        "EVT2-B06",
        "EVT2-B07",
        "EVT2-B08"
      ]
    },
    "owner_role": {
      "type": "string",
      "enum": [
        "Event transport contract owner",
        "Persistence contract owner",
        "Retention and legal-hold contract owner",
        "Cryptographic security contract owner",
        "Data classification contract owner",
        "Subscription governance contract owner",
        "Event audit contract owner",
        "Causation integrity contract owner"
      ]
    },
    "proposed_accountable_party_id": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "proposed_authority_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_category", "source_reference", "evidence_hash"],
      "properties": {
        "source_category": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "source_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" }
      }
    },
    "proposed_authority_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "proposed_authority_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "decision_surfaces"],
      "properties": {
        "blocker_id": {
          "type": "string",
          "enum": [
            "EVT2-B01",
            "EVT2-B02",
            "EVT2-B03",
            "EVT2-B04",
            "EVT2-B05",
            "EVT2-B06",
            "EVT2-B07",
            "EVT2-B08"
          ]
        },
        "decision_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" }
        }
      }
    },
    "submission_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "submitted_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" },
    "intake_status": { "const": "SUBMITTED_UNVERIFIED" },
    "submitted_evidence_status": { "const": "unverified" },
    "accountable_party_status": { "const": "UNASSIGNED" },
    "authority_reference_status": { "const": "ABSENT" },
    "contains_credentials": { "const": false },
    "contains_secrets": { "const": false },
    "contains_unnecessary_personal_data": { "const": false },
    "identity_established": { "const": false },
    "authority_established": { "const": false },
    "party_assigned": { "const": false },
    "approval_granted": { "const": false },
    "blocker_resolved": { "const": false }
  }
}
