{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoauth.local/schemas/event-bus-v2-authority-assignment-review.schema.json",
  "title": "EchoAuth Event Bus v2 Authority Assignment Review",
  "description": "Structure-only assignment-review evidence. A recommendation is not assignment, authority, approval, blocker resolution, execution permission, or register mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assignment_review_schema_version",
    "assignment_review_id",
    "intake_id",
    "blocker_id",
    "eligibility_record_reference",
    "eligibility_record_hash",
    "source_eligibility_outcome",
    "complete_evidence_chain",
    "proposed_party_reference",
    "proposed_party_reference_hash",
    "proposed_authority_evidence_reference",
    "proposed_authority_evidence_hash",
    "assignment_reviewer_party_reference",
    "assignment_reviewer_party_reference_hash",
    "assignment_reviewer_authority",
    "review_evidence_references",
    "review_evidence_hash",
    "evidence_provenance",
    "blocker_scope_alignment",
    "reviewer_independence_check",
    "conflict_check",
    "assignment_review_evidence_outcome",
    "assignment_review_outcome",
    "assignment_review_reason_codes",
    "resulting_intake_state",
    "protocol_phase",
    "register_mutation_status",
    "reviewed_at",
    "hold_status",
    "contains_credentials",
    "contains_secrets",
    "contains_excess_personal_data",
    "self_assignment_review_detected",
    "prior_authority_evidence_reused",
    "inferred_reviewer_authority",
    "recommendation_is_assignment",
    "identity_established",
    "party_assigned",
    "authority_assigned",
    "authority_reference_granted",
    "authority_record_created",
    "approval_granted",
    "contract_approved",
    "blocker_resolved",
    "blockers_resolved",
    "execution_authorized",
    "runtime_enabled",
    "register_mutated",
    "runtime_effect"
  ],
  "properties": {
    "assignment_review_schema_version": { "const": "2.0.0" },
    "assignment_review_id": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "intake_id": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "blocker_id": {
      "type": "string",
      "enum": ["EVT2-B01", "EVT2-B02", "EVT2-B03", "EVT2-B04", "EVT2-B05", "EVT2-B06", "EVT2-B07", "EVT2-B08"]
    },
    "eligibility_record_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "eligibility_record_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "source_eligibility_outcome": { "const": "ELIGIBLE_FOR_AUTHORITY_REVIEW" },
    "complete_evidence_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submission_reference", "submission_hash",
        "verification_reference", "verification_hash",
        "admission_reference", "admission_hash",
        "governance_review_reference", "governance_review_hash",
        "review_disposition_reference", "review_disposition_hash",
        "eligibility_reference", "eligibility_hash",
        "lifecycle_reconciliation_reference", "lifecycle_reconciliation_hash"
      ],
      "properties": {
        "submission_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "submission_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "verification_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "verification_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "admission_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "admission_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "governance_review_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "governance_review_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "review_disposition_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "review_disposition_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "eligibility_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "eligibility_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "lifecycle_reconciliation_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "lifecycle_reconciliation_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" }
      }
    },
    "proposed_party_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "proposed_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "proposed_authority_evidence_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "proposed_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "assignment_reviewer_party_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "assignment_reviewer_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "assignment_reviewer_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_reference", "authority_reference", "scope_hash", "status", "issued_at", "expires_at", "evidence_hash"],
      "properties": {
        "source_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "authority_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "scope_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "status": { "const": "ACTIVE" },
        "issued_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" },
        "expires_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" }
      }
    },
    "review_evidence_references": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" }
    },
    "review_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "evidence_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_category", "source_reference", "evidence_hash", "observed_at"],
      "properties": {
        "source_category": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "source_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "observed_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" }
      }
    },
    "blocker_scope_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "candidate_scope_hash", "reviewer_scope_hash", "outcome"],
      "properties": {
        "blocker_id": {
          "type": "string",
          "enum": ["EVT2-B01", "EVT2-B02", "EVT2-B03", "EVT2-B04", "EVT2-B05", "EVT2-B06", "EVT2-B07", "EVT2-B08"]
        },
        "candidate_scope_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "reviewer_scope_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "outcome": { "const": "ALIGNED" }
      }
    },
    "reviewer_independence_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposed_party_reference_hash", "reviewer_party_reference_hash", "prior_authority_evidence_hashes", "reviewer_authority_evidence_hash", "outcome", "evidence_hash"],
      "properties": {
        "proposed_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "reviewer_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "prior_authority_evidence_hashes": {
          "type": "array", "minItems": 5, "uniqueItems": true,
          "items": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" }
        },
        "reviewer_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "outcome": { "const": "DISTINCT_AND_INDEPENDENT" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" }
      }
    },
    "conflict_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "checked_references_hash", "evidence_hash"],
      "properties": {
        "outcome": { "const": "CLEAR" },
        "checked_references_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" }
      }
    },
    "assignment_review_evidence_outcome": { "enum": ["SATISFIED", "INCOMPLETE", "INVALID", "CONFLICT"] },
    "assignment_review_outcome": {
      "enum": [
        "CANDIDATE_RECOMMENDED_FOR_ASSIGNMENT_DECISION",
        "ADDITIONAL_ASSIGNMENT_EVIDENCE_REQUIRED",
        "CANDIDATE_REJECTED_FOR_ASSIGNMENT_DECISION"
      ]
    },
    "assignment_review_reason_codes": {
      "type": "array", "uniqueItems": true,
      "items": {
        "enum": ["MISSING_EVIDENCE", "CONFLICTING_EVIDENCE", "REVIEWER_AUTHORITY_INVALID", "SCOPE_MISMATCH", "SELF_ASSIGNMENT_REVIEW", "REUSED_PRIOR_AUTHORITY_EVIDENCE", "CANDIDATE_EVIDENCE_INVALID"]
      }
    },
    "resulting_intake_state": { "const": "ACCEPTED_FOR_REVIEW" },
    "protocol_phase": { "const": "AUTHORITY_ASSIGNMENT_REVIEW" },
    "register_mutation_status": { "const": "PROSPECTIVE_EVIDENCE_ONLY" },
    "reviewed_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" },
    "hold_status": { "const": "ACTIVE" },
    "contains_credentials": { "const": false },
    "contains_secrets": { "const": false },
    "contains_excess_personal_data": { "const": false },
    "self_assignment_review_detected": { "const": false },
    "prior_authority_evidence_reused": { "const": false },
    "inferred_reviewer_authority": { "const": false },
    "recommendation_is_assignment": { "const": false },
    "identity_established": { "const": false },
    "party_assigned": { "const": false },
    "authority_assigned": { "const": false },
    "authority_reference_granted": { "const": false },
    "authority_record_created": { "const": false },
    "approval_granted": { "const": false },
    "contract_approved": { "const": false },
    "blocker_resolved": { "const": false },
    "blockers_resolved": { "const": false },
    "execution_authorized": { "const": false },
    "runtime_enabled": { "const": false },
    "register_mutated": { "const": false },
    "runtime_effect": { "const": "NONE" }
  },
  "oneOf": [
    {
      "properties": {
        "assignment_review_evidence_outcome": { "const": "SATISFIED" },
        "assignment_review_outcome": { "const": "CANDIDATE_RECOMMENDED_FOR_ASSIGNMENT_DECISION" },
        "assignment_review_reason_codes": { "maxItems": 0 }
      }
    },
    {
      "properties": {
        "assignment_review_evidence_outcome": { "const": "INCOMPLETE" },
        "assignment_review_outcome": { "const": "ADDITIONAL_ASSIGNMENT_EVIDENCE_REQUIRED" },
        "assignment_review_reason_codes": { "minItems": 1 }
      }
    },
    {
      "properties": {
        "assignment_review_evidence_outcome": { "enum": ["INVALID", "CONFLICT"] },
        "assignment_review_outcome": { "const": "CANDIDATE_REJECTED_FOR_ASSIGNMENT_DECISION" },
        "assignment_review_reason_codes": { "minItems": 1 }
      }
    }
  ]
}
