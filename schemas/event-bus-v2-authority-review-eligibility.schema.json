{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoauth.local/schemas/event-bus-v2-authority-review-eligibility.schema.json",
  "title": "EchoAuth Event Bus v2 Authority Review Eligibility",
  "description": "Structure-only eligibility evidence for authority review consideration. Eligibility does not assign authority, approve a contract, resolve a blocker, authorize execution, or mutate the current register.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eligibility_schema_version",
    "eligibility_id",
    "intake_id",
    "blocker_id",
    "disposition_record_reference",
    "disposition_record_hash",
    "source_disposition_outcome",
    "source_intake_status",
    "disposition_party_reference_hash",
    "disposition_authority_evidence_hash",
    "review_authority_evidence_hash",
    "admission_authority_evidence_hash",
    "verification_authority_evidence_hash",
    "eligibility_party_reference",
    "eligibility_party_reference_hash",
    "eligibility_authority_evidence_reference",
    "eligibility_authority_evidence_hash",
    "eligibility_evidence_references",
    "eligibility_evidence_hash",
    "evidence_provenance",
    "scope_alignment",
    "eligibility_independence_check",
    "eligibility_evidence_outcome",
    "eligibility_outcome",
    "eligibility_reason_codes",
    "resulting_intake_status",
    "evaluated_at",
    "effect_boundary",
    "hold_status",
    "contains_credentials",
    "contains_secrets",
    "contains_excess_personal_data",
    "self_eligibility_detected",
    "disposition_authority_evidence_reused",
    "review_authority_evidence_reused",
    "admission_authority_evidence_reused",
    "verifier_authority_evidence_reused",
    "favorable_disposition_sufficient",
    "inferred_eligibility",
    "inferred_authority",
    "identity_established",
    "party_assigned",
    "authority_assigned",
    "authority_reference_granted",
    "approval_granted",
    "contract_approved",
    "blocker_resolved",
    "blockers_resolved",
    "execution_authorized",
    "runtime_enabled",
    "current_register_mutated",
    "runtime_effect"
  ],
  "properties": {
    "eligibility_schema_version": { "const": "2.0.0" },
    "eligibility_id": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "intake_id": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "blocker_id": {
      "type": "string",
      "enum": ["EVT2-B01", "EVT2-B02", "EVT2-B03", "EVT2-B04", "EVT2-B05", "EVT2-B06", "EVT2-B07", "EVT2-B08"]
    },
    "disposition_record_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "disposition_record_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "source_disposition_outcome": {
      "enum": [
        "FAVORABLE_REVIEW_EVIDENCE_RETAINED",
        "INFORMATION_REQUEST_EVIDENCE_RETAINED",
        "REVIEW_REJECTION_EVIDENCE_RETAINED"
      ]
    },
    "source_intake_status": { "enum": ["ACCEPTED_FOR_REVIEW", "REJECTED"] },
    "disposition_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "disposition_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "review_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "admission_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "verification_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "eligibility_party_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "eligibility_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "eligibility_authority_evidence_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "eligibility_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "eligibility_evidence_references": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" }
    },
    "eligibility_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "evidence_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_category", "source_reference", "evidence_hash", "observed_at"],
      "properties": {
        "source_category": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "source_reference": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "observed_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" }
      }
    },
    "scope_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "disposition_scope_hash", "eligibility_scope_hash", "outcome"],
      "properties": {
        "blocker_id": {
          "type": "string",
          "enum": ["EVT2-B01", "EVT2-B02", "EVT2-B03", "EVT2-B04", "EVT2-B05", "EVT2-B06", "EVT2-B07", "EVT2-B08"]
        },
        "disposition_scope_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "eligibility_scope_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "outcome": { "const": "ALIGNED" }
      }
    },
    "eligibility_independence_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disposition_party_reference_hash",
        "eligibility_party_reference_hash",
        "verification_authority_evidence_hash",
        "admission_authority_evidence_hash",
        "review_authority_evidence_hash",
        "disposition_authority_evidence_hash",
        "eligibility_authority_evidence_hash",
        "outcome",
        "evidence_hash"
      ],
      "properties": {
        "disposition_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "eligibility_party_reference_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "verification_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "admission_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "review_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "disposition_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "eligibility_authority_evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
        "outcome": { "const": "DISTINCT_AND_INDEPENDENT" },
        "evidence_hash": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" }
      }
    },
    "eligibility_evidence_outcome": { "enum": ["SATISFIED", "INCOMPLETE", "INVALID", "CONFLICT"] },
    "eligibility_outcome": {
      "enum": [
        "ELIGIBLE_FOR_AUTHORITY_REVIEW",
        "ADDITIONAL_EVIDENCE_REQUIRED",
        "INELIGIBLE_FOR_AUTHORITY_REVIEW"
      ]
    },
    "eligibility_reason_codes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "MISSING_EVIDENCE",
          "CONFLICTING_EVIDENCE",
          "ELIGIBILITY_AUTHORITY_EVIDENCE_INVALID",
          "PROVENANCE_INVALID",
          "SCOPE_MISMATCH",
          "SELF_ELIGIBILITY",
          "REUSED_PRIOR_AUTHORITY_EVIDENCE",
          "DISPOSITION_NOT_FAVORABLE"
        ]
      }
    },
    "resulting_intake_status": { "enum": ["ACCEPTED_FOR_REVIEW", "REJECTED"] },
    "evaluated_at": { "$ref": "event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" },
    "effect_boundary": { "const": "REVIEW_CONSIDERATION_ONLY" },
    "hold_status": { "const": "ACTIVE" },
    "contains_credentials": { "const": false },
    "contains_secrets": { "const": false },
    "contains_excess_personal_data": { "const": false },
    "self_eligibility_detected": { "const": false },
    "disposition_authority_evidence_reused": { "const": false },
    "review_authority_evidence_reused": { "const": false },
    "admission_authority_evidence_reused": { "const": false },
    "verifier_authority_evidence_reused": { "const": false },
    "favorable_disposition_sufficient": { "const": false },
    "inferred_eligibility": { "const": false },
    "inferred_authority": { "const": false },
    "identity_established": { "const": false },
    "party_assigned": { "const": false },
    "authority_assigned": { "const": false },
    "authority_reference_granted": { "const": false },
    "approval_granted": { "const": false },
    "contract_approved": { "const": false },
    "blocker_resolved": { "const": false },
    "blockers_resolved": { "const": false },
    "execution_authorized": { "const": false },
    "runtime_enabled": { "const": false },
    "current_register_mutated": { "const": false },
    "runtime_effect": { "const": "NONE" }
  },
  "oneOf": [
    {
      "properties": {
        "source_disposition_outcome": { "const": "FAVORABLE_REVIEW_EVIDENCE_RETAINED" },
        "source_intake_status": { "const": "ACCEPTED_FOR_REVIEW" },
        "eligibility_evidence_outcome": { "const": "SATISFIED" },
        "eligibility_outcome": { "const": "ELIGIBLE_FOR_AUTHORITY_REVIEW" },
        "eligibility_reason_codes": { "maxItems": 0 },
        "resulting_intake_status": { "const": "ACCEPTED_FOR_REVIEW" }
      }
    },
    {
      "properties": {
        "source_disposition_outcome": { "const": "FAVORABLE_REVIEW_EVIDENCE_RETAINED" },
        "source_intake_status": { "const": "ACCEPTED_FOR_REVIEW" },
        "eligibility_evidence_outcome": { "const": "INCOMPLETE" },
        "eligibility_outcome": { "const": "ADDITIONAL_EVIDENCE_REQUIRED" },
        "eligibility_reason_codes": { "minItems": 1 },
        "resulting_intake_status": { "const": "ACCEPTED_FOR_REVIEW" }
      }
    },
    {
      "properties": {
        "source_disposition_outcome": { "const": "FAVORABLE_REVIEW_EVIDENCE_RETAINED" },
        "source_intake_status": { "const": "ACCEPTED_FOR_REVIEW" },
        "eligibility_evidence_outcome": { "enum": ["INVALID", "CONFLICT"] },
        "eligibility_outcome": { "const": "INELIGIBLE_FOR_AUTHORITY_REVIEW" },
        "eligibility_reason_codes": { "minItems": 1 },
        "resulting_intake_status": { "const": "ACCEPTED_FOR_REVIEW" }
      }
    },
    {
      "properties": {
        "source_disposition_outcome": { "const": "INFORMATION_REQUEST_EVIDENCE_RETAINED" },
        "source_intake_status": { "const": "ACCEPTED_FOR_REVIEW" },
        "eligibility_evidence_outcome": { "const": "INCOMPLETE" },
        "eligibility_outcome": { "const": "ADDITIONAL_EVIDENCE_REQUIRED" },
        "eligibility_reason_codes": { "minItems": 1 },
        "resulting_intake_status": { "const": "ACCEPTED_FOR_REVIEW" }
      }
    },
    {
      "properties": {
        "source_disposition_outcome": { "const": "REVIEW_REJECTION_EVIDENCE_RETAINED" },
        "source_intake_status": { "const": "REJECTED" },
        "eligibility_evidence_outcome": { "enum": ["INVALID", "CONFLICT"] },
        "eligibility_outcome": { "const": "INELIGIBLE_FOR_AUTHORITY_REVIEW" },
        "eligibility_reason_codes": { "minItems": 1 },
        "resulting_intake_status": { "const": "REJECTED" }
      }
    }
  ]
}
