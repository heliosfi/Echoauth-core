{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoauth.local/events/event-envelope-v2.schema.json",
  "title": "EchoAuth Event Envelope v2",
  "description": "Draft v2 event evidence envelope. Validation does not publish, deliver, persist, replay, authorize, execute, or append audit records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_version",
    "event_id",
    "event_type",
    "producer_id",
    "correlation_id",
    "event_schema_id",
    "event_schema_version",
    "payload_schema_id",
    "payload_schema_version",
    "confidentiality_class",
    "integrity_class",
    "payload",
    "payload_hash",
    "occurred_at"
  ],
  "properties": {
    "envelope_version": { "const": "2.0" },
    "event_id": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "event_type": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "producer_id": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "request_id": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "correlation_id": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "causation_id": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "event_schema_id": {
      "const": "https://echoauth.local/events/event-envelope-v2.schema.json"
    },
    "event_schema_version": { "const": "2.0.0" },
    "payload_schema_id": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "payload_schema_version": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/NonEmptyString" },
    "confidentiality_class": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/ConfidentialityClass" },
    "integrity_class": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/IntegrityClass" },
    "payload": {
      "type": "object",
      "description": "Canonical JSON object selected by event_type and events/event-catalog-v2.yaml.",
      "additionalProperties": true
    },
    "payload_hash": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/Sha256Hex" },
    "occurred_at": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/UtcTimestamp" },
    "signature_evidence": { "$ref": "../schemas/event-bus-runtime-v2.schema.json#/$defs/SignatureEvidence" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "integrity_class": { "const": "high" }
        },
        "required": ["integrity_class"]
      },
      "then": {
        "required": ["signature_evidence"]
      }
    }
  ]
}
